{
  "manifest_version": 3,
  "name": "Professor Ratings for Banner",
  "version": "1.1.1",
  "description": "Inline Rate My Professor ratings on Banner SSB9 course registration pages",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.ratemyprofessors.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/StudentRegistrationSsb/*",
        "https://*/ssb/*classRegistration*",
        "https://*/ssb/*scheduleDetails*"
      ],
      "js": ["name-parser.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RMP Ratings — choose school",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
