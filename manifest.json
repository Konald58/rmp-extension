{
  "manifest_version": 3,
  "name": "Professor Ratings for Course Search",
  "version": "2.0.0",
  "description": "Inline Rate My Professors ratings on Banner, PeopleSoft, and other course registration systems.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.ratemyprofessors.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/StudentRegistrationSsb/*",
        "https://*/ssb/*classRegistration*",
        "https://*/ssb/*scheduleDetails*",
        "https://*/*COMMUNITY_ACCESS.CLASS_SEARCH.GBL*"
      ],
      "js": [
        "content/name-parser.js",
        "content/common.js",
        "content/adapters/banner.js",
        "content/adapters/peoplesoft.js",
        "content/index.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Professor Ratings — choose school",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
