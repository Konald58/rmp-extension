{
  "manifest_version": 3,
  "name": "USF Professor Ratings",
  "version": "1.0.0",
  "description": "Inline RMP ratings in USF Banner course registration",
  "permissions": ["storage"],
  "host_permissions": [
    "https://studentssb9.it.usf.edu/*",
    "https://www.ratemyprofessors.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://studentssb9.it.usf.edu/*"],
      "js": ["name-parser.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
